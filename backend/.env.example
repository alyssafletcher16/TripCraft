DATABASE_URL="postgresql://postgres:password@localhost:5432/tripcraft"
PORT=4000
NEXTAUTH_SECRET="your-secret-here-change-in-production"
FRONTEND_URL="http://localhost:3000"

# ── Partner API keys ──────────────────────────────────────────────────────────
VIATOR_API_KEY="your-viator-api-key"
AWIN_OAUTH_TOKEN="your-awin-oauth-token"

# ── Affiliate partner IDs (set real values before going live) ─────────────────
# Add these as NEXT_PUBLIC_* vars in frontend/.env.local (or Vercel env settings)
NEXT_PUBLIC_VIATOR_AFFILIATE_ID="VIATOR_ID_HERE"
NEXT_PUBLIC_GETYOURGUIDE_AFFILIATE_ID="GYG_ID_HERE"
NEXT_PUBLIC_AWIN_AFFILIATE_ID="AWIN_ID_HERE"
NEXT_PUBLIC_BOOKING_COM_AWIN_MID="BOOKING_MID_HERE"
