generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth compatible) ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips         Trip[]
  upvotes       CommunityUpvote[]
  accounts      Account[]
  sessions      Session[]
  bookingClicks BookingClick[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Trips ───────────────────────────────────────────────────────────────────

model Trip {
  id          String     @id @default(cuid())
  userId      String
  title       String
  destination String
  country     String?
  startDate   DateTime?
  endDate     DateTime?
  travelers   Int        @default(1)
  budget      Float?
  budgetType  String     @default("total") // "total" | "per_person"
  status      TripStatus @default(PLANNING)
  isPublic    Boolean    @default(false)
  rank        Int?       // personal ranking 1–5
  coverEmoji  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  vibes           TripVibe[]
  days            ItineraryDay[]
  reflection      TripReflection?
  insights        TripInsight[]
  upvotes         CommunityUpvote[]
  checklist       ChecklistItem[]
  community       Community?
  itineraryImport ItineraryImport?
}

enum TripStatus {
  PLANNING
  ACTIVE
  COMPLETED
}

model TripVibe {
  id     String @id @default(cuid())
  tripId String
  vibe   String // "adventure" | "foodie" | "cultural" | "romantic" | etc.

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, vibe])
}

// ─── Itinerary Days ──────────────────────────────────────────────────────────

model ItineraryDay {
  id     String    @id @default(cuid())
  tripId String
  dayNum Int
  name   String
  theme  String?
  date   DateTime?

  trip   Trip         @relation(fields: [tripId], references: [id], onDelete: Cascade)
  blocks Block[]
  photos DayPhoto[]

  @@unique([tripId, dayNum])
}

// ─── Blocks (bookings / activities / notes) ──────────────────────────────────

model Block {
  id           String        @id @default(cuid())
  dayId        String
  type         BlockType
  title        String
  detail       String?
  price        String?       // display string e.g. "$142/nt"
  priceValue   Float?        // numeric for sorting/filtering
  status       BookingStatus @default(PENDING)
  confCode     String?
  cancelPolicy String?
  cancelSafe   Boolean       @default(false)
  bookingUrl   String?
  emoji        String?
  bgColor      String?
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

enum BlockType {
  TRANSPORT
  STAY
  ACTIVITY
  FOOD
  NOTE
}

enum BookingStatus {
  BOOKED
  PENDING
  CANCELLED
}

// ─── Photos ──────────────────────────────────────────────────────────────────

model DayPhoto {
  id        String   @id @default(cuid())
  dayId     String
  url       String?
  emoji     String?
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  day ItineraryDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

// ─── Trip Reflection (post-trip, 8 fields) ───────────────────────────────────

model TripReflection {
  id           String   @id @default(cuid())
  tripId       String   @unique
  rank         Int?     // 0–100 (personal ranking)
  expectation  String?  // "Better than expected" | "Exactly what I imagined" | etc.
  sentence     String?  // one-sentence trip summary
  changes      String[] // what they'd change next time
  bestDecision String?
  regret       String?
  rebook       Json?    // { "Hot Air Balloon": "Absolutely", ... }
  tripTitle    String?  // personal title e.g. "The Trek That Changed Everything"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ─── Trip Insights (synthesized review intelligence) ─────────────────────────

model TripInsight {
  id     String      @id @default(cuid())
  tripId String
  type   InsightType @default(INFO)
  text   String
  source String?     // e.g. "840 reviews · TripAdvisor, GetYourGuide"
  color  String?     // hex, for UI badge

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

enum InsightType {
  INFO
  WARNING
  DANGER
}

// ─── Pre-trip Checklist ──────────────────────────────────────────────────────

model ChecklistItem {
  id       String  @id @default(cuid())
  tripId   String
  label    String
  deadline String?
  done     Boolean @default(false)
  sortOrder Int    @default(0)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ─── Community / Discover ────────────────────────────────────────────────────

// ─── Places API Cache ─────────────────────────────────────────────────────────

model PlaceCache {
  id          String   @id @default(cuid())
  placeId     String   @unique
  name        String
  type        String
  rating      Float
  reviewCount Int
  priceLevel  Int?
  reviews     Json
  photos      Json
  address     String
  website     String?
  phone       String?
  hours       Json?
  lastFetched DateTime
  createdAt   DateTime @default(now())
}

// ─── Booking Click Tracking ───────────────────────────────────────────────────

model BookingClick {
  id            String   @id @default(cuid())
  userId        String
  tripId        String?
  blockId       String?
  activityTitle String
  platform      String   // "getyourguide" | "viator" | "booking"
  url           String
  timestamp     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Community / Discover ────────────────────────────────────────────────────

model Community {
  id          String  @id @default(cuid())
  tripId      String  @unique
  isPublic    Boolean @default(false)
  friendsOnly Boolean @default(false)
  isAnonymous Boolean @default(false)
  upvotes     Int     @default(0)

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model ItineraryImport {
  id           String   @id @default(cuid())
  tripId       String   @unique
  fileName     String
  sourceFormat String
  confidence   Float
  parseNotes   String?
  createdAt    DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model CommunityUpvote {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}
